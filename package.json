{
  "name": "findias",
  "version": "1.2.0",
  "description": "Findias - a mod manager for Mabinogi",
  "author": "tekashi-side",
  "license": "MIT",
  "private": true,
  "main": "./out/main/index.js",
  "build": {
    "appId": "side.tekashi.findias",
    "productName": "Findias",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "!docs/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!vite.config.{js,ts,mjs,cjs}",
      "!{.eslintignore,.prettierignore,.prettierrc,.editorconfig,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc}",
      "!{tsconfig.json,tsconfig.node.json,tsconfig.web.json}",
      "!{release-please-config.json,.release-please-manifest.json,.node-version}"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "tekashi-side",
      "repo": "Findias"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:win": "electron-vite build && electron-builder --win",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,css}": "prettier --write"
  }
}
